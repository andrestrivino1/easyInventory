<IfModule mod_rewrite.c>
    RewriteEngine On

    # Si la peticion ya apunta a public/, no reescribir (evita bucle)
    RewriteRule ^public/ - [L]

    # Redirige todas las peticiones a la carpeta public de Laravel
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Evita el listado de directorios
Options -Indexes
